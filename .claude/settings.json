{
  "_readme": [
    "Drop this file into your project as .claude/settings.json (or merge into an existing one).",
    "Adjust the base path if you placed framework/ somewhere other than docs/harness/.",
    "The default paths assume framework/ was copied to docs/harness/ inside your project.",
    "To add a new check, drop a .py file into the relevant subdirectory \u2014 no edits here needed.",
    "See docs/harness/vendor/harnessable/references/hooks.md for the full wiring guide."
  ],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 docs/harness/hooks/run.py pre_tool_use"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 docs/harness/hooks/run.py post_tool_use"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 docs/harness/hooks/run.py stop"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 docs/harness/hooks/pre_compact/transcript_archive.py"
          },
          {
            "type": "command",
            "command": "python3 docs/harness/hooks/pre_compact/mandate_snapshot.py"
          }
        ]
      }
    ]
  }
}
